	# get next nav point
		# if no next nav point, then create a new navigation goal
	if not navigation.is_navigating():
		if memory.has(Memory.Key.LONG_TERM_DESTINATION):
			navigation.set_new_pathfinding_location_explicit(memory.get_value(Memory.Key.LONG_TERM_DESTINATION))
