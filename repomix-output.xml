	c.allow_slip = allow_slip
	c.contact_damage = contact_damage
	c.walkable_tags = walkable_tags.duplicate()
	c.fall_damage = fall_damage
	c.kill_on_fall = kill_on_fall
	c.transport_target = transport_target
