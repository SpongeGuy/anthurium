	stage += 1
	advanced_to_stage.emit(stage)
	
func decrement_stage() -> void:
	if stage - 1 < min_stage:
		return
	
	stage -= 1
	demoted_to_stage.emit(stage)

func _ready() -> void:
	_init_set_stage()
