	if randf() < 0.5:
		return
		
	var dirs: Array = [
		Vector2(1, 0),
		Vector2(0, 1),
		Vector2(-1, 0),
		Vector2(0, -1)
	]
	var is_wall_in_front: bool = true
	var dir: Vector2
	
	for i in range(25):
		if is_wall_in_front:
